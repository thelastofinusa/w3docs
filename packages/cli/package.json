{
  "name": "@w3docs/cli",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "bin": {
    "w3docs": "./bin/w3docs.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts && chmod +x bin/w3docs.js",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@w3docs/core": "workspace:*",
    "@inquirer/prompts": "^5.0.0"
  },
  "devDependencies": {
    "@w3docs/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
