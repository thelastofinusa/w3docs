{
  "name": "w3docs-monorepo",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "cli": "pnpm --filter w3docs dev",
    "web": "pnpm --filter web dev",
    "demo": "pnpm --filter demo dev",
    "pushout": "pnpm --filter w3docs pushout",
    "pushout-inc": "pnpm --filter w3docs pushout-inc"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
